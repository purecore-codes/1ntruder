{
  "name": "1ntruder",
  "version": "0.1.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "1ntruder": "./src/cli.js",
    "intruder": "./src/cli.js",
    "1ntruder-cve": "./src/cli-cve.js",
    "intruder-cve": "./src/cli-cve.js"
  },
  "scripts": {
    "build": "node ./src/cli.js --banner",
    "prebuild": "node ./src/cli.js --security-check || true",
    "postinstall": "node ./src/cli.js --welcome || true",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "1ntruder": "node ./src/cli.js",
    "intruder": "node ./src/cli.js",
    "scan": "node ./src/cli.js scan",
    "fuzz": "node ./src/cli.js fuzz",
    "recon": "node ./src/cli.js recon",
    "start": "node ./src/cli.js",
    "cve": "node ./src/cli-cve.js cve",
    "deps": "node ./src/cli-cve.js deps",
    "cve:search": "node ./src/cli-cve.js cve search",
    "cve:recent": "node ./src/cli-cve.js cve recent",
    "cve:critical": "node ./src/cli-cve.js cve critical",
    "cve:monitor": "node ./src/cli-cve.js cve monitor",
    "cve:report": "node ./src/cli-cve.js cve report"
  },
  "keywords": ["pentesting", "security", "http", "scanner", "fuzzer", "hacking", "cybersecurity", "cve", "vulnerability"],
  "author": "PureCore Codes",
  "license": "MIT",
  "description": "Advanced HTTP security scanner and pentesting toolkit with CVE monitoring",
  "devDependencies": {
    "jest": "^30.2.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "axios": "^1.15.0"
  }
}
